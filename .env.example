# MT5 Router SaaS Configuration

# App
APP_NAME=MT5 Router
APP_VERSION=2.0.0
DEBUG=false
HOST=0.0.0.0
PORT=8080

# Security
JWT_SECRET=change-this-to-a-secure-random-string-64-chars-min
ENCRYPTION_KEY=your-fernet-key-here

# Database (SQLite default, PostgreSQL for production)
DATABASE_URL=sqlite:///./data/mt5router.db
# For PostgreSQL:
# DATABASE_URL=postgresql://mt5router:password@postgres:5432/mt5router

# Docker
MT5_IMAGE=lprett/mt5linux:mt5-installed

# Rate Limiting
RATE_LIMIT_PER_MINUTE=100

# CORS
CORS_ORIGINS=*

# Telegram Notifications (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Webhooks
WEBHOOK_SECRET=

# SaaS Billing (future)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_BASIC=
STRIPE_PRICE_ID_PRO=
